<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="Site.master.cs" Inherits="student_information_management_system.Site" %>
<!DOCTYPE html>
<html lang="en">
<head runat="server">
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><asp:ContentPlaceHolder ID="TitlePlaceholder" runat="server">INTI Student Portal</asp:ContentPlaceHolder></title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="<%= ResolveUrl("~/css/site.css") %>" rel="stylesheet" />

    <asp:ContentPlaceHolder ID="HeadPlaceholder" runat="server" />
</head>
<body class="font-sans antialiased text-slate-900" style="font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">
    <form id="form1" runat="server">
        <asp:ContentPlaceHolder ID="BodyPlaceholder" runat="server" />
    </form>

    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="<%= ResolveUrl("~/js/shared/icons-init.js") %>"></script>
    <asp:ContentPlaceHolder ID="ScriptsPlaceholder" runat="server" />
</body>
</html>