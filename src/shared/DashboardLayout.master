<%@ Master Language="C#" MasterPageFile="~/shared/site.master" AutoEventWireup="true" CodeBehind="DashboardLayout.master.cs" Inherits="src.shared.DashboardLayout" %>
<%@ Register TagPrefix="uc" TagName="Sidebar" Src="~/controls/sidebar.ascx" %>
<%@ Register TagPrefix="uc" TagName="Topbar" Src="~/controls/topbar.ascx" %>

<asp:Content ContentPlaceHolderID="BodyPlaceholder" runat="server">
    <div class="flex min-h-screen bg-slate-50/60">
        <div id="mobile-menu-backdrop" data-open="false" class="fixed inset-0 z-40 bg-slate-900/50 opacity-0 pointer-events-none transition-opacity duration-300 data-[open=true]:opacity-100 data-[open=true]:pointer-events-auto lg:hidden"></div>
        <uc:Sidebar runat="server" ID="Sidebar1" />
        <div class="flex-1 flex flex-col min-w-0">
            <uc:Topbar runat="server" ID="Topbar1" />
            <main class="flex-1 px-6 py-8 lg:px-10">
                <asp:ContentPlaceHolder ID="MainContent" runat="server" />
            </main>
        </div>
    </div>
</asp:Content>

<asp:Content ContentPlaceHolderID="HeadPlaceholder" runat="server">
    <asp:ContentPlaceHolder ID="HeadPlaceholder" runat="server" />
</asp:Content>

<asp:Content ContentPlaceHolderID="ScriptsPlaceholder" runat="server">
    <asp:ContentPlaceHolder ID="ScriptsPlaceholder" runat="server" />
</asp:Content>
